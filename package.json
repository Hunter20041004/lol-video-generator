{
  "name": "lol-video-generator",
  "version": "1.0.0",
  "description": "Bilingual LoL data-to-video pipeline with guarded social publishing.",
  "main": "scraper.js",
  "scripts": {
    "dev": "next dev --webpack",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:unit": "node --test \"tests/unit/**/*.test.js\"",
    "test:coverage": "node scripts/runCoverage.js",
    "test:watch": "node --test --watch \"tests/**/*.test.js\"",
    "tdd:doctor": "node scripts/tddDoctor.js",
    "verify": "npm run tdd:doctor && npm run test:coverage && npx next build",
    "worker": "node worker.js",
    "worker:now": "node worker.js --now",
    "worker:dry": "node worker.js --now --dry",
    "cache:create": "node scripts/manageCache.js create",
    "cache:list": "node scripts/manageCache.js list",
    "cache:delete": "node scripts/manageCache.js delete",
    "cache:clear": "node scripts/manageCache.js clear-all",
    "qa:render": "node scripts/qaRender.js",
    "publish:queue": "node scripts/publishQueue.js list",
    "publish:run": "node scripts/publishQueue.js run",
    "publish:due": "node scripts/publishQueue.js run --due",
    "publish:scheduler": "node scripts/publishScheduler.js",
    "insights:sync": "node scripts/insightsSync.js",
    "media:cleanup": "node scripts/cleanupMedia.js",
    "insights:scheduler": "node scripts/insightsScheduler.js",
    "portfolio:render": "remotion render src/index.jsx MetaTierRankingVideo public/demo/meta-tier-ranking.mp4 --muted --frames=0-179",
    "portfolio:capture": "node scripts/capturePortfolioEvidence.js"
  },
  "keywords": [
    "remotion",
    "nextjs",
    "content-automation",
    "league-of-legends"
  ],
  "author": "Hunter Tseng（曾尉庭）",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@remotion/bundler": "4.0.489",
    "@remotion/cli": "4.0.489",
    "@remotion/compositor-darwin-arm64": "4.0.489",
    "@remotion/licensing": "4.0.489",
    "@remotion/media-parser": "4.0.489",
    "@remotion/media-utils": "4.0.489",
    "@remotion/player": "4.0.489",
    "@remotion/renderer": "4.0.489",
    "@remotion/streaming": "4.0.489",
    "@remotion/studio": "4.0.489",
    "@remotion/studio-server": "4.0.489",
    "@remotion/studio-shared": "4.0.489",
    "@remotion/web-renderer": "4.0.489",
    "@remotion/zod-types": "4.0.489",
    "axios": "^1.15.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "googleapis": "^171.4.0",
    "next": "^16.2.4",
    "node-cron": "^4.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remotion": "4.0.489",
    "zod": "^4.3.6"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
