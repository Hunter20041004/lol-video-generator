GEMINI_API_KEY=
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Required for YouTube OAuth. One OAuth app can connect both zh/en channels.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Written automatically by /api/auth/google?locale=zh and ?locale=en
YOUTUBE_ZH_REFRESH_TOKEN=
YOUTUBE_EN_REFRESH_TOKEN=
YOUTUBE_ZH_PRIVACY_STATUS=private
YOUTUBE_EN_PRIVACY_STATUS=private

# Required for Instagram / Threads / TikTok video publishing.
# Must be a public HTTPS base URL where public/renders/*.mp4 can be fetched.
PUBLIC_MEDIA_BASE_URL=

# Required for Meta OAuth setup.
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_BASE_URL=http://localhost:3000

INSTAGRAM_ZH_USER_ID=
INSTAGRAM_ZH_ACCESS_TOKEN=
INSTAGRAM_EN_USER_ID=
INSTAGRAM_EN_ACCESS_TOKEN=

THREADS_ZH_USER_ID=
THREADS_ZH_ACCESS_TOKEN=
THREADS_EN_USER_ID=
THREADS_EN_ACCESS_TOKEN=
THREADS_ALLOW_TEXT_ONLY=false

TIKTOK_ZH_ACCESS_TOKEN=
TIKTOK_EN_ACCESS_TOKEN=
TIKTOK_PRIVACY_LEVEL=SELF_ONLY

# Instagram + Threads post performance tracking.
# Fresh posts sync hourly, posts under 7 days every 6 hours, older posts daily.
INSIGHTS_SCHEDULER_CRON=15 * * * *
INSIGHTS_FRESH_INTERVAL_MINUTES=60
INSIGHTS_RECENT_INTERVAL_MINUTES=360
INSIGHTS_ARCHIVE_INTERVAL_MINUTES=1440
INSIGHTS_ERROR_RETRY_MINUTES=60
INSIGHTS_AUTH_RETRY_MINUTES=1440
INSIGHTS_MAX_SNAPSHOTS=30
